{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2020"],

    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "incremental": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "noEmitOnError": true,
    "noImplicitThis": true,

    "ignoreDeprecations": "6.0",

    "outDir": "dist",
    "rootDir": "."
  },

  "include": [
    "./",
    "./**/*.ts",
    "./**/*.js",
    "src/**/*.json"
  ],

  "exclude": [
    "node_modules/",
    "build/",
    "dist/",
    ".cache/",
    ".tmp/",
    "src/admin/",
    "**/*.test.*",
    "src/plugins/**"
  ]
}
